def draw_map(surf,cam_x,cam_y):
    # 타일
    sx=int(cam_x//TILE)*TILE; sy=int(cam_y//TILE)*TILE
    for ty in range(sy, int(cam_y)+SH+TILE, TILE):
        for tx in range(sx, int(cam_x)+SW+TILE, TILE):
            if 0<=tx<MAP_W and 0<=ty<MAP_H:
                c=C_FL if ((tx//TILE)+(ty//TILE))%2==0 else C_FL2
                pygame.draw.rect(surf,c,(tx-cam_x,ty-cam_y,TILE,TILE))
    # 맵 경계 벽
    for tx in range(0,MAP_W,TILE):
        pygame.draw.rect(surf,C_WALL,(tx-cam_x,-cam_y,TILE,TILE))
        pygame.draw.rect(surf,C_WTOP,(tx-cam_x,-cam_y,TILE,4))
        pygame.draw.rect(surf,C_WALL,(tx-cam_x,MAP_H-TILE-cam_y,TILE,TILE))
    for ty in range(0,MAP_H,TILE):
        pygame.draw.rect(surf,C_WALL,(-cam_x,ty-cam_y,TILE,TILE))
        pygame.draw.rect(surf,C_WALL,(MAP_W-TILE-cam_x,ty-cam_y,TILE,TILE))
    # 장식 오브젝트
    for dx,dy,dk in DECO:
        sx2=dx-cam_x; sy2=dy-cam_y
        if -TILE<sx2<SW+TILE and -TILE<sy2<SH+TILE:
            if dk==0:   # 돌기둥
                pygame.draw.rect(surf,(55,45,70),(sx2+8,sy2+4,32,40))
                pygame.draw.rect(surf,(75,62,92),(sx2+8,sy2+4,32,6))
            elif dk==1: # 풀
                for i in range(5):
                    h=random.randint(8,18)
                    pygame.draw.rect(surf,(50,100,50),(sx2+i*9+2,sy2+TILE-h,3,h))
            elif dk==2: # 뼈
                pygame.draw.rect(surf,(170,170,150),(sx2+12,sy2+18,24,8))
                pygame.draw.rect(surf,(170,170,150),(sx2+14,sy2+10,6,20))
                pygame.draw.rect(surf,(170,170,150),(sx2+28,sy2+10,6,20))
            else:       # 묘비
                pygame.draw.rect(surf,(80,70,100),(sx2+14,sy2+12,20,28))
                pygame.draw.rect(surf,(80,70,100),(sx2+14,sy2+8,20,10))
                pygame.draw.rect(surf,(100,90,120),(sx2+22,sy2+18,4,14))
                pygame.draw.rect(surf,(100,90,120),(sx2+16,sy2+22,16,4))

def get_cam(pl):
    return (max(0,min(pl.cx-SW/2,MAP_W-SW)),
            max(0,min(pl.cy-SH/2,MAP_H-SH)))

