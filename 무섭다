# ───────────── 메인 ─────────────
def main():
    pygame.init()
    pygame.display.set_caption("SPEAR SURVIVORS")
    screen=pygame.display.set_mode((SW,SH))
    clock=pygame.time.Clock()

    ST,SP,WIN,LOSE="title","play","win","lose"
    state=ST; tick=0

    def new_game():
        pl=Player()
        spawn=SpawnManager()
        enemies=[]; thrown=[]; proj=[]; ps=[]
        elapsed=0.0
        return pl,spawn,enemies,thrown,proj,ps,elapsed

    pl,spawn,enemies,thrown,proj,ps,elapsed=new_game()
    final_score=0
    mb_l=mb_r=False; ke=kr=False

    while True:
        dt=clock.tick(FPS)/1000.0; tick+=1
        keys=pygame.key.get_pressed()
        mx,my=pygame.mouse.get_pos()
        mb_l=kr=ke=False

        for ev in pygame.event.get():
            if ev.type==pygame.QUIT: pygame.quit();sys.exit()
            if ev.type==pygame.KEYDOWN:
                if ev.key==pygame.K_ESCAPE: pygame.quit();sys.exit()
                if state==ST and ev.key in (pygame.K_SPACE,pygame.K_RETURN):
                    pl,spawn,enemies,thrown,proj,ps,elapsed=new_game(); state=SP
                elif state in (WIN,LOSE):
                    if ev.key==pygame.K_r:
                        pl,spawn,enemies,thrown,proj,ps,elapsed=new_game(); state=SP
                    elif ev.key in (pygame.K_SPACE,pygame.K_RETURN): state=ST
                elif state==SP:
                    if ev.key==pygame.K_e: ke=True
                    if ev.key==pygame.K_r: kr=True
            if ev.type==pygame.MOUSEBUTTONDOWN:
                if ev.button==1: mb_l=True
                if ev.button==3: mb_r=True
            if ev.type==pygame.MOUSEBUTTONUP:
                if ev.button==3: mb_r=False

        if state==ST:
            draw_title(screen,tick); pygame.display.flip(); continue

        if state in (WIN,LOSE):
            screen.fill(C_BG)
            fn=pfont(52); fs=pfont(22)
            col=C_GRN if state==WIN else C_RED
            msg="CLEAR!" if state==WIN else "GAME OVER"
            ov=pygame.Surface((SW,SH),pygame.SRCALPHA); ov.fill((0,0,0,160)); screen.blit(ov,(0,0))
            t=fn.render(msg,False,col); screen.blit(t,(SW//2-t.get_width()//2,SH//2-80))
            sub=f"SCORE {final_score}  처치 {pl.kills}  |  R:재시작  ENTER:타이틀"
            s=fs.render(sub,False,C_WHITE); screen.blit(s,(SW//2-s.get_width()//2,SH//2+10))
            pygame.display.flip(); continue

        # ── PLAY ──
        cam_x,cam_y=get_cam(pl)
        elapsed+=dt

        pl.update(keys,dt,mx,my,cam_x,cam_y,enemies,ps,thrown,mb_l,mb_r,ke,kr)

        # 투척 창
        for sp in thrown[:]:
            sp.update(enemies,ps,pl)
            if not sp.alive: thrown.remove(sp)

        # 적 업데이트
        prev=len(enemies)
        for e in enemies[:]:
            if not e.alive:
                sparks(ps,e.cx,e.cy,e.col,18)
                pl.score+=e.sc; pl.kills+=1
                if isinstance(e,Boss): spawn.boss_alive=False
                enemies.remove(e); continue
            if isinstance(e,Boss): e.update(pl,ps,proj)
            else: e.update(pl,ps)

        # 보스 투사체
        for p in proj[:]:
            p.update()
            if not p.alive: proj.remove(p); continue
            if dist(p.x,p.y,pl.cx,pl.cy)<16:
                par=pl.take_dmg(18,ps)
                sparks(ps,p.x,p.y,C_PARRY if par else (180,80,255),10)
                proj.remove(p)

        # 파티클
        for pt in ps[:]:
            pt.update()
            if pt.life<=0: ps.remove(pt)

        # 스폰
        spawn.update(pl,enemies,ps,dt)

        if pl.hp<=0: final_score=pl.score; state=LOSE

        # ── 렌더 ──
        screen.fill(C_BG)
        draw_map(screen,cam_x,cam_y)

        for pt in ps: pt.draw(screen,cam_x,cam_y)
        for p in proj: p.draw(screen,cam_x,cam_y)
        for sp in thrown: sp.draw(screen,cam_x,cam_y)
        for e in enemies: e.draw(screen,cam_x,cam_y)
        pl.draw(screen,cam_x,cam_y,ps)
        draw_hud(screen,pl,elapsed,spawn.wave,enemies,spawn)
        draw_minimap(screen,pl,enemies)

        # 웨이브 알림 (웨이브 시작 직후 2초)
        if spawn.wave_t<2.0:
            fn=pfont(32); msg=f"WAVE {spawn.wave}"+(" ─ BOSS!" if spawn.boss_alive else "")
            tsh(screen,msg,fn,C_GOLD,SW//2-fn.size(msg)[0]//2,SH//2-20)

        pygame.display.flip()

if __name__=="__main__":
    main()
