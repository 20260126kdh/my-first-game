C_RED=(220,50,50); C_GRN=(80,200,100); C_HPBK=(40,20,20)
C_SHADOW=(10,8,16)

# 플레이어
PLR_SPD=4; PLR_HP=150
# 찌르기
ST_DMG=35; ST_RNG=95; ST_CD=18; ST_FR=10
