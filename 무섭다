# 장식용 타일: 돌기둥, 풀 등 — 충돌 없는 배경 오브젝트
DECO=[]
random.seed(99)
for _ in range(320):
    DECO.append((random.randint(0,MAP_W//TILE-1)*TILE,
                 random.randint(0,MAP_H//TILE-1)*TILE,
